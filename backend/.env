# Server configurations
PORT=5000

# Instagram Integration API Configuration
# To connect to your real Instagram page:
# 1. Register a developer account at developers.facebook.com
# 2. Add the Instagram Basic Display API product.
# 3. Generate a Long-Lived User Access Token.
# 4. Paste your access token below.
INSTAGRAM_ACCESS_TOKEN=YOUR_INSTAGRAM_ACCESS_TOKEN_HERE

# ── Security & Auth ──────────────────────────────────────────────────────────
# Secret key used to sign session tokens (change this to a long random string)
JWT_SECRET=ohpolly_super_secret_jwt_key_change_in_production_2026

# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# How long (minutes) a session stays valid before auto-logout
SESSION_DURATION_MINUTES=30

# Max failed login attempts before account lockout
MAX_LOGIN_ATTEMPTS=5

# Lockout duration in minutes after max attempts reached
LOCKOUT_DURATION_MINUTES=5
