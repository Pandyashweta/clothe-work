{
  "name": "ohpolly-api",
  "version": "1.0.0",
  "description": "Oh Polly secure Express API — Zero Trust architecture",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start":   "node server.js",
    "dev":     "node --watch server.js",
    "audit":   "npm audit --audit-level=high",
    "audit:fix": "npm audit fix"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bcryptjs":           "^2.4.3",
    "cors":               "^2.8.6",
    "dotenv":             "^17.4.2",
    "express":            "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "express-validator":  "^7.2.1",
    "helmet":             "^8.1.0",
    "uuid":               "^11.1.0"
  }
}
